{
  "description": "Prompt English Coach checks English prompts on UserPromptSubmit and displays non-blocking feedback after Stop.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/coach-hook.js", "${user_config.mode}"],
            "timeout": 30,
            "statusMessage": "Checking prompt English"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/coach-hook.js", "${user_config.mode}"],
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/coach-hook.js", "${user_config.mode}"],
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/coach-hook.js", "${user_config.mode}"],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
